# ── Required ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...           # anon/public key from Supabase
SUPABASE_SERVICE_KEY=eyJ...        # service_role key (server-side only)

# ── Optional (Groq for video transcription) ─────────
GROQ_API_KEY=gsk_...               # For Whisper transcription fallback

# ── Optional (Stripe billing) ───────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_xxx
STRIPE_PRICE_ID_AGENCY=price_yyy

# ── Optional (Cron publish secret) ──────────────────
CRON_SECRET=choose-a-strong-random-string

# ── Auto-detected (override if needed) ──────────────
APP_URL=https://your-app.onrender.com
PORT=3000
NODE_ENV=production
