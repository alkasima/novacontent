# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_FREE=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_AGENCY=price_...

# App
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:3001

# AI providers are configured in the in-app Superadmin dashboard (/admin),
# not via env vars. Make yourself superadmin via supabase-schema.sql.

# Cron (set a strong random secret for /api/cron/publish)
CRON_SECRET=your-strong-random-secret
